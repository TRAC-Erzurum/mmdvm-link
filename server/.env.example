# Merkezi Yönetim Sunucusu (Central Controller)
# Kopyala (Linux/macOS): cp .env.example .env
# Kopyala (Windows PowerShell): Copy-Item .env.example .env
# Kopyala (Windows cmd): copy .env.example .env
# Sonra .env içindeki değerleri doldur

# MQTT broker
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# Broker şifre dosyası (mosquitto_passwd ile kullanıcı eklenir); sunucu yazma yetkisine sahip olmalı
BROKER_PASSWORD_FILE=

# Binding persist (opsiyonel)
# - Varsayılan: açık (server/bindings.json)
# - Kapatmak için: PERSIST_BINDINGS=0
# - Yol override etmek için: BINDINGS_PATH=C:\path\to\bindings.json
PERSIST_BINDINGS=1
BINDINGS_PATH=

# installer script içinde client'a verilecek adres (broker veya sunucu)
SERVER_ADDR=localhost
