# Merkezi Yönetim Sunucusu
# Kopyala: cp .env.example .env ve değerleri doldur

# Broker'a bağlanmak için sunucu tarafı token
SECRET_TOKEN=

# MQTT broker adresi (örn. trac-erzurum broker)
MQTT_BROKER=localhost
# MQTT_BROKER=mqtt.example.com

# İsteğe bağlı: port, kullanıcı, şifre
# MQTT_PORT=1883
# MQTT_USER=
# MQTT_PASSWORD=
